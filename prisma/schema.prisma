// Datag — persistence layer
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Auth + cloud-saved profile ----

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  nickname      String   @unique
  coins         Int      @default(0)
  upgrades      String[] @default([]) // upgrade ids the user has bought
  matchesPlayed Int      @default(0)
  createdAt     DateTime @default(now())
  matches       MatchPlayer[]
}

// ---- Match history & leaderboard ----

model Match {
  id         String        @id @default(cuid())
  roomCode   String
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  scoreA     Int           @default(0)
  scoreB     Int           @default(0)
  winner     String?       // "A" | "B" | "DRAW"
  players    MatchPlayer[]
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  userId   String?
  nickname String
  team     String // "A" | "B"
  role     String // "TAGER" | "LIGHTER"
  hits     Int    @default(0)
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user     User?  @relation(fields: [userId], references: [id])
}

model Leaderboard {
  nickname  String   @id
  wins      Int      @default(0)
  losses    Int      @default(0)
  hits      Int      @default(0)
  matches   Int      @default(0)
  updatedAt DateTime @updatedAt
}

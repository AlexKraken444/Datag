# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database (Prisma / PostgreSQL) ---
# Required for email/password auth and cloud-saved profiles.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/datag?schema=public"

# --- Auth.js / NextAuth ---
# Generate with `openssl rand -base64 32`. Required.
AUTH_SECRET="replace-me-with-32-bytes-of-randomness"
# On Vercel: leave unset (auto-detected). Locally: optional.
# AUTH_URL=http://localhost:3000

# --- Socket / public ---
# Optional. If empty, the client uses window.location.origin.
NEXT_PUBLIC_SOCKET_URL=""
